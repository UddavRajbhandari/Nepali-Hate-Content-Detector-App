# ── Development ────────────────────────────────────────────────────────────────
# Leave empty — Vite proxy forwards /api/* to http://localhost:8000 automatically
# VITE_API_BASE=

# ── Production (Vercel / Netlify) ──────────────────────────────────────────────
# Set this to your deployed Railway / HuggingFace Spaces backend URL
# VITE_API_BASE=https://your-backend.up.railway.app/api
